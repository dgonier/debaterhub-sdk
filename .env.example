# DebaterHub SDK Environment Variables
# Get real values from 1Password: "DebaterHub SDK Environment" secure note
# Or ask a team member for a share link

# LiveKit (required for all SDK operations)
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# OpenAI (required for E2E tests that use the judge model)
OPENAI_API_KEY=sk-your-openai-key
